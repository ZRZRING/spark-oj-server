# https://goframe.org/docs/web/server-config-file-template
server:
  address:     ":8000"
  openapiPath: "/api.json"
  swaggerPath: "/swagger"

# https://goframe.org/docs/core/glog-config
logger:
  path: "output"
  file: "{Y-m-d}.log"
  level : "all"
  stdout: true
  header: true

redis:
  default:
    address: "zrzring.top:6379"
    password: "zrzring"
    db: 0

# https://goframe.org/docs/core/gdb-config-file
database:
  logger:
    path: "output"
    file: "{Y-m-d}.db.log"
    level: "all"
    # stdout: true
  default:
    # link: "pgsql:spark-oj:123456@tcp(zrzring.top:54321)/spark-oj"
    link: "pgsql:postgres:postgres@tcp(127.0.0.1:5432)/spark-oj"
    timezone: "Asia/Shanghai"
    debug: true

# 自定义配置

upload:
  path:
    testcases: "data/testcases"

judge:
  apiBaseUrl: "http://localhost:5050"
  timeout: 15