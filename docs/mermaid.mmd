%%{
  init: {
    'theme': 'base',
    'themeVariables': {
      'background': '#ffffff',
      'primaryColor': '#ffcccc'
    }
  }
}%%
graph LR
%% --- 左侧子模块 (最外层) ---
L1_S1([注册与查重])
L1_S2([MD5登录])
L2_S1([公告展示])
L2_S2([系统引导])
L3_S1([记录列表分页])
L3_S2([记录信息详情])

    %% --- 左侧主模块 ---
    L1([用户注册登录])
    L2([主页公告展示])
    L3([提交记录展示])

    %% --- 中心角色 ---
    User((普通用户))

    %% --- 右侧主模块 ---
    R1([题目展示])
    R2([题目提交功能])
    R3([比赛展示])

    %% --- 右侧子模块 (最外层) ---
    R1_S1([列表分页/检索])
    R1_S2([Markdown/KaTeX渲染])
    R2_S1([源码提交详情])
    R2_S2([比赛筛选/摘要])
    R3_S1([比赛列表/详情])
    R3_S2([实时榜单/封榜])

    %% --- 关系连接 ---

    %% 左侧：箭头向左指 (Main -> Sub)
    L1_S1 <-.- |include| L1
    L1_S2 <-.- |include| L1
    L2_S1 <-.- |include| L2
    L2_S2 <-.- |include| L2
    L3_S1 <-.- |include| L3
    L3_S2 <-.- |include| L3

    %% 用户关联
    L1 --- User
    L2 --- User
    L3 --- User
    User --- R1
    User --- R2
    User --- R3

    %% 右侧：箭头向右指 (Main -> Sub)
    R1 -.-> |include| R1_S1
    R1 -.-> |include| R1_S2
    R2 -.-> |include| R2_S1
    R2 -.-> |include| R2_S2
    R3 -.-> |include| R3_S1
    R3 -.-> |include| R3_S2

    %% 样式美化
    style User fill:#f9f,stroke:#333,stroke-width:2px
    style L1 fill:#fff3e0,stroke:#fb8c00
    style L2 fill:#fff3e0,stroke:#fb8c00
    style L3 fill:#fff3e0,stroke:#fb8c00
    style R1 fill:#e8f5e9,stroke:#43a047
    style R2 fill:#e8f5e9,stroke:#43a047
    style R3 fill:#e8f5e9,stroke:#43a047